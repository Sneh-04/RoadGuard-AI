# ============================================
# RoadGuard Backend Configuration
# ============================================

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=roadguard_db
PRODUCTION=false

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# WebSocket Settings
WS_HOST=YOUR-IP
WS_PORT=8000

# Location & Geolocation
GEOLOCATION_SERVICE=geopy

# Model Configuration
MODEL_PATH=./models/best.pt
STAGE1_MODEL=./models/stage1_binary_v2.keras
STAGE2_MODEL=./models/stage2_subtype_v2.keras

# Mobile App
MOBILE_API_URL=ws://YOUR-IP:8000/ws/live

# Logging
LOG_LEVEL=INFO
